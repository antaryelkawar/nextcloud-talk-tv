{
  "$schema": "https://opencode.ai/config.json",
  "model": "local/gemma-4-26b",
  "small_model": "local/gemma-4-26b",
  "provider": {
    "local": {
      "options": {
        "baseURL": "http://192.168.1.39:8080/v1"
      },
      "models": {
        "gemma-4-26b": {
          "name": "Local: Gemma 4 26B"
        }
      }
    }
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"]
    }
  },
  "agent": {
    "build": {
      "description": "Main development agent with full tool access",
      "model": "local/gemma-4-26b"
    },
    "plan": {
      "description": "Planning agent - analyzes and suggests without making changes",
      "model": "local/gemma-4-26b",
      "permission": {
        "edit": "ask",
        "bash": "ask"
      }
    },
    "general": {
      "description": "General-purpose agent for multi-step tasks",
      "mode": "subagent",
      "model": "local/gemma-4-26b"
    },
    "explore": {
      "description": "Fast exploration agent - read-only code analysis",
      "mode": "subagent",
      "model": "local/gemma-4-26b",
      "tools": {
        "read": true,
        "grep": true,
        "glob": true
      }
    },
    "code-reviewer": {
      "description": "Code review agent - analyzes code quality and suggests improvements",
      "mode": "subagent",
      "model": "local/gemma-4-26b",
      "tools": {
        "read": true,
        "grep": true,
        "glob": true,
        "edit": false,
        "write": false
      },
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": "allow"
      }
    },
    "docs-writer": {
      "description": "Documentation writer agent - generates and maintains docs",
      "mode": "subagent",
      "model": "local/gemma-4-26b",
      "tools": {
        "read": true,
        "write": true,
        "edit": true
      }
    },
    "security-auditor": {
      "description": "Security audit agent - finds vulnerabilities and security issues",
      "mode": "subagent",
      "model": "local/gemma-4-26b",
      "tools": {
        "read": true,
        "grep": true,
        "glob": true,
        "edit": false,
        "write": false
      },
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": "allow"
      }
    }
  },
  "permission": {
    "edit": "allow",
    "bash": "allow"
  }
}
